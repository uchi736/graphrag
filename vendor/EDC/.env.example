# =====================================================================
# EDC 完全オンプレ構成（このファイルが実際に参照する設定のみ）
# graphrag 由来の未使用設定(GRAPH_*/NEO4J_*/PG_*/RERANKER_*/VLLM_VISION_*/
# LANGFUSE_*)は EDC コードから一切読まれないため削除済み。
# =====================================================================

# ---------------------------------------------------------------------
# LLM Provider (Chat)
# ---------------------------------------------------------------------
# 稼働中のチャットLLMは gemma-4 26B-A4B FP8 @ 8000（旧 Qwen3 @8001 は停止中）
LLM_PROVIDER=vllm
VLLM_ENDPOINT=http://192.168.0.250:8000/v1
VLLM_MODEL=google/gemma-4-31B-it
VLLM_API_KEY=dummy
# 旧: VLLM_ENDPOINT=http://192.168.0.250:8001/v1 / VLLM_MODEL=cpatonn/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit

# 1回のAPI呼び出しのタイムアウト秒 / 最大リトライ回数（停止時に無限ハングしない）
VLLM_TIMEOUT=300
VLLM_MAX_RETRIES=5

# ---------------------------------------------------------------------
# Embedding (vLLM上のruri-v3-310m, 日本語特化768次元)
# ---------------------------------------------------------------------
VLLM_EMBEDDING_ENDPOINT=http://192.168.0.250:8003/v1
VLLM_EMBEDDING_MODEL=cl-nagoya/ruri-v3-310m

# 正規化の類似度マージ閾値（cosine）。LLMが「該当なし」でも最近傍の既存
# 関係/型との類似度がこの値以上なら新規追加せず統合し、スキーマの増殖を防ぐ。
# 高い=厳しく統合(新規が増えやすい) / 低い=積極的に統合(語彙が小さく保たれる)。
CANON_MERGE_THRESHOLD=0.9

# ---------------------------------------------------------------------
# PDF 前処理（完全オンプレ）
# ---------------------------------------------------------------------
# PDF_PROCESSOR=onprem + PDF_BACKEND=paddleocr_remote で PaddleX PP-OCRv5 を使用。
# Azure DI へ戻す場合は PDF_PROCESSOR=azure_di（下の AZURE_DI_* も要コメント解除）。
PDF_PROCESSOR=onprem
PDF_BACKEND=paddleocr_remote
PADDLEX_ENDPOINT=http://192.168.0.250:8005
PADDLEX_TIMEOUT=180

# =====================================================================
# Azure 系（緊急ロールバック用。完全オンプレ運用中は参照されない）
# LLM/Embedding を Azure に戻す場合はコメント解除し、app.py で "Azure OpenAI" を選択、
# または run.py --provider azure。PDF を Azure DI に戻す場合は PDF_PROCESSOR=azure_di。
# =====================================================================
# AZURE_OPENAI_API_KEY=<your-key>
# AZURE_OPENAI_ENDPOINT=https://uchiwaapi.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
# AZURE_DI_ENDPOINT=https://testbaghba.cognitiveservices.azure.com/
# AZURE_DI_API_KEY=<your-key>
# AZURE_DI_MODEL=prebuilt-layout
