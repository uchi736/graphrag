# ===== 画像生成・編集アプリ 環境変数サンプル =====
# コピーして imagegen/.env として使うか、シェルで export する。

# ComfyUI の接続先（DGX Spark 上で起動している ComfyUI）
COMFYUI_URL=http://127.0.0.1:8188

# 完了ポーリング間隔（秒）と 1 ジョブの最大待ち時間（秒）
COMFYUI_POLL_INTERVAL=1.5
IMAGEGEN_JOB_TIMEOUT=900

# ComfyUI への HTTP タイムアウト（秒）
COMFYUI_HTTP_TIMEOUT=30

# 結果画像・アップロード画像の保存先（未指定なら imagegen/outputs, imagegen/uploads）
# IMAGEGEN_OUTPUT_DIR=/data/imagegen/outputs
# IMAGEGEN_UPLOAD_DIR=/data/imagegen/uploads

# 別オリジン（Vite dev server 等）から叩く場合のみ（カンマ区切り）
# IMAGEGEN_CORS_ORIGINS=http://localhost:5173
