# =====================================================================
# graphrag - 完全オンプレ構成サンプル
# =====================================================================
# DGX Spark 等のオンプレマシン上で動作する vLLM/PaddleX/Neo4j/PGVector を
# 想定したテンプレ。Azure系へ戻す場合は末尾のロールバックブロックを参照。
# =====================================================================

# Neo4j Configuration (必須)
# ローカルDocker: bolt://localhost:7687
# DGX Spark など LAN: bolt://192.168.0.250:7687
# Neo4j Aura (cloud): neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PW=changeme123

# PostgreSQL Configuration
# PGVector拡張がインストールされたPostgreSQLの接続文字列
PG_CONN=postgresql+psycopg://postgres:your_password@your-host:5432/postgres
# コレクション名（他プログラムとの衝突防止）
PG_COLLECTION=graphrag

# Graph backend
GRAPH_BACKEND=neo4j
GRAPH_SEARCH_STRATEGY=path

# ---------------------------------------------------------------------
# LLM Provider (Chat)
# ---------------------------------------------------------------------
# "vllm"        = セルフホストvLLM (オンプレ既定)
# "azure_openai"= Azure OpenAI Service (ロールバック用)
LLM_PROVIDER=vllm
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=google/gemma-4-26B-A4B-it
VLLM_API_KEY=EMPTY
VLLM_TEMPERATURE=0.0
VLLM_MAX_TOKENS=4096
VLLM_TIMEOUT=300
# gpt-oss 系 (harmony format) 用: low / medium / high。Gemma/Qwen3では無視される
VLLM_REASONING_EFFORT=low

# ---------------------------------------------------------------------
# Embedding Provider
# ---------------------------------------------------------------------
# "vllm"        = セルフホストvLLM (オンプレ既定)
# "azure_openai"= Azure OpenAI text-embedding-3-small等 (ロールバック用)
# ※切替時は次元が変わるため scripts/reset_pgvector_tables.py → scripts/build_kg.py で再構築必須
# (Azure text-embedding-3-small=1536, ruri-v3-310m=768, bge-m3=1024, Qwen3-Embedding-8B=4096)
EMBEDDING_PROVIDER=vllm
VLLM_EMBEDDING_ENDPOINT=http://localhost:8003/v1
VLLM_EMBEDDING_MODEL=cl-nagoya/ruri-v3-310m
VLLM_EMBEDDING_API_KEY=EMPTY

# ---------------------------------------------------------------------
# Reranker (cross-encoder on vLLM /v1/score)
# ---------------------------------------------------------------------
# LLM rerank より 10-100倍速い。false ならLLM rerank にフォールバック
RERANKER_ENABLED=true
VLLM_RERANKER_ENDPOINT=http://localhost:8006/v1
VLLM_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
VLLM_RERANKER_API_KEY=EMPTY

# ---------------------------------------------------------------------
# PDF 前処理
# ---------------------------------------------------------------------
# "onprem"   = preprocessing_optimizer 経由（オンプレ既定）
# "azure_di" = Azure Document Intelligence (ロールバック用)
# "pymupdf"  = PyMuPDFプレーン（最軽量・図表解析なし）
PDF_PROCESSOR=onprem
# preprocessing_optimizer の画像解析バックエンド: vllm|paddleocr|hybrid|none|paddleocr_remote
PDF_BACKEND=paddleocr_remote

# PaddleX PP-OCRv5 (CPU OCR) - PDF_BACKEND=paddleocr_remote で使用
PADDLEX_ENDPOINT=http://localhost:8005
PADDLEX_TIMEOUT=180

# PaddleX Layout (レイアウト検出専用) - graphrag側の呼出は未実装、env登録のみ
PADDLEX_LAYOUT_ENDPOINT=http://localhost:8007

# Vision vLLM (PDF_BACKEND=vllm のとき使用)
# VLLM_VISION_ENDPOINT=http://localhost:8004/v1
# VLLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# VLLM_VISION_API_KEY=EMPTY

# preprocessing_optimizer プロジェクトのパス（相対はgraphragルート基準）
PREPROCESSING_OPTIMIZER_PATH=../preprocessing_optimizer

# ---------------------------------------------------------------------
# Knowledge Graph / Retrieval
# ---------------------------------------------------------------------
ENABLE_KNOWLEDGE_GRAPH=true
GRAPH_HOP_COUNT=2
PATH_MAX_CANDIDATES=30

ENABLE_ENTITY_VECTOR_SEARCH=true
# 同義語/表記揺れ補完は高類似度が必須。0.85 が実効既定（旧バージョンは内部で0.85へ切り上げ）。
ENTITY_SIMILARITY_THRESHOLD=0.85

# グラフ三つ組の "A --rel--> B" 行をコンテキストに含めるか。
# EXPERIMENTS.md: noLines がマルチホップで優位のため既定OFF。
INCLUDE_GRAPH_LINES=false

ENABLE_JAPANESE_SEARCH=true
JAPANESE_MIN_TOKEN_LENGTH=2

RETRIEVAL_TOP_K=5
SEARCH_MODE=hybrid
# 検索結果の cross-encoder リランク（最強レバー +11.8pt, EXPERIMENTS.md）→ 既定ON。
# 注: RERANKER_ENABLED(上記) は cross-encoder の master switch で別物。
#     ENABLE_RERANK=パイプライン側のメイン文書リランク有効化フラグ。
ENABLE_RERANK=true
INCLUDE_KG_SOURCE_CHUNKS=true

# 外部KGスキーマファイル(EDC等)。未設定ならデフォルト12関係
# SHARED_SCHEMA_PATH=../shared/kg_schema.json
# SHARED_GRAPH_JSON_PATH=../shared/graph.json

# 専門用語辞書 (任意, JSON or CSV)
# 指定すると build_kg 末尾で Term ノードに canonical_form / aliases /
# category / definition を後付けする
# KG_DICTIONARY_PATH=_eval/term_dictionary_モデル就業規則.json

# ---------------------------------------------------------------------
# Langfuse Tracing (Optional)
# ---------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# =====================================================================
# Rollback ブロック: Azure OpenAI / Azure DI を使う場合のみ値を入れる
# 完全オンプレ運用時はすべて空でOK（sidebar 等の必須チェックも条件分岐済み）
# =====================================================================
# LLM_PROVIDER=azure_openai もしくは EMBEDDING_PROVIDER=azure_openai のとき必須:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=

# LLM_PROVIDER=openai (OpenAI公式 gpt-4.1 等) のとき必須:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TIMEOUT=120

# LLM_PROVIDER=anthropic (Claude) のとき必須:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT=120

# PDF_PROCESSOR=azure_di のとき必須:
AZURE_DI_ENDPOINT=
AZURE_DI_API_KEY=
AZURE_DI_MODEL=prebuilt-layout
